<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="12dp">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_view" app:tint="#A0AEC0" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="12sp" android:textColor="#A0AEC0" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navCalendar" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" app:tint="#A0AEC0" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calendar" android:textSize="12sp" android:textColor="#A0AEC0" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical" android:background="?android:attr/selectableItemBackground">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="#A0AEC0" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="12sp" android:textColor="#A0AEC0" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Check-in"
                android:textSize="32sp"
                android:textColor="#1A202C"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track your daily metrics for accurate analysis."
                android:textSize="16sp"
                android:textColor="#718096"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXERCISE DURATION"
                        android:textSize="11sp"
                        android:textColor="#A0AEC0"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etExerciseMinutes"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Total Minutes (e.g. 45)"
                        android:inputType="number"
                        android:background="#F1F3F4"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exercise Intensity"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"/>

                    <Spinner
                        android:id="@+id/spinnerIntensity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SLEEP DURATION"
                        android:textSize="11sp"
                        android:textColor="#A0AEC0"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etSleepHours"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Total Hours (e.g. 7.5)"
                        android:inputType="numberDecimal"
                        android:background="#F1F3F4"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIET QUALITY"
                        android:textSize="11sp"
                        android:textColor="#A0AEC0"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/rgFoodType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbHealthy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nourishing"
                            android:textColor="#2D3748"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Whole foods, vegetables, high protein, and minimal processed sugar."
                            android:textSize="13sp"
                            android:textColor="#718096"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="16dp" />

                        <RadioButton
                            android:id="@+id/rbNormal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Balanced"
                            android:textColor="#2D3748"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="A mix of home-cooked meals and occasional snacks or outside food."
                            android:textSize="13sp"
                            android:textColor="#718096"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="16dp" />

                        <RadioButton
                            android:id="@+id/rbUnhealthy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Treat / Heavy"
                            android:textColor="#2D3748"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="High in salt, saturated fats, fast food, or sugary desserts."
                            android:textSize="13sp"
                            android:textColor="#718096"
                            android:layout_marginStart="32dp"
                            android:layout_marginBottom="8dp" />

                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnSaveDailyRecord"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="Save Record"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#4299E1"
                app:cornerRadius="32dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnBackToMain"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Cancel"
                android:textColor="#718096"
                android:background="@android:color/transparent"
                app:strokeColor="#CBD5E0"
                app:strokeWidth="1dp"
                app:cornerRadius="32dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>