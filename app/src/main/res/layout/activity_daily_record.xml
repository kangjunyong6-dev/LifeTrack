<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Purple top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#673AB7"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Record"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- White area below purple bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="0dp">

            <Button
                android:id="@+id/btnBackToMain"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#673AB7" />

            <!-- Green card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="#4CAF50"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Health"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track your daily activity"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Input"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginBottom="20dp" />

            <!-- White Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exercise Duration"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etExerciseMinutes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Minutes"
                    android:inputType="number"
                    android:padding="14dp"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food Type"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginBottom="10dp" />

                <RadioGroup
                    android:id="@+id/rgFoodType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <RadioButton
                        android:id="@+id/rbHealthy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Healthy"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rbUnhealthy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unhealthy" />
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sleep Duration"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etSleepHours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Hours"
                    android:inputType="numberDecimal"
                    android:padding="14dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveDailyRecord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Record"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#512DA8" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>